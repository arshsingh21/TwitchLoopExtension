{
  "manifest_version": 3,
  "name": "TwitchLoop",
  "version": "1.4",
  "description": "Automatically cycles through browser tabs, refreshing each one on a configurable interval.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "twitchloop@extension.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "developer": {
    "name": "TwitchLoop Developer",
    "url": "https://github.com/arshsingh21/TwitchLoopExtension"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "commands": {
    "toggle-cycling": {
      "suggested_key": {
        "default": "F2"
      },
      "description": "Start or stop tab cycling"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}