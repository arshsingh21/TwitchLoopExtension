{
  "manifest_version": 2,
  "name": "TwitchLoop",
  "version": "1.0",
  "description": "Automatically cycles through browser tabs, refreshing each one on a configurable interval.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "twitchloop@extension.local"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
